# Copy to `.env` in this folder and fill in. Used by deploy/azure/docker-compose.yml.

# Public backend API hostname, DNS -> this VM's public IP (Cloudflare, grey cloud).
# Do NOT include https:// — just the hostname.
DOMAIN=api.aguzmancruz.com

# Email for Let's Encrypt expiry notices (any real address).
TLS_EMAIL=you@example.com

# Exact frontend origin allowed by CORS. The API uses credentials, so this MUST
# be a single explicit origin (wildcard "*" is rejected by browsers).
CORS_ORIGINS=https://aguzmancruz.com

# Host path for persistent data (SQLite + LanceDB). Point at the mounted Azure
# managed data disk. Native ext4 keeps SQLite WAL locking reliable.
DATA_HOST_PATH=/mnt/ragdata

# --- LLM provider: groq | nvidia | gemini | openrouter | hf | local ---
LLM_PROVIDER=groq

# Set the key for whichever provider you selected above.
GROQ_API_KEY=
NVIDIA_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HF_TOKEN=
