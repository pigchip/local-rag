# Copy to `.env` in this folder and fill in. Used by deploy/oracle/docker-compose.yml.

# Your public domain pointing at the VM's IP (e.g. a free DuckDNS subdomain).
# Do NOT include https:// — just the hostname.
DOMAIN=your-app.duckdns.org

# Email for Let's Encrypt expiry notices (any real address).
TLS_EMAIL=you@example.com

# --- LLM provider: groq | nvidia | gemini | openrouter | hf | local ---
LLM_PROVIDER=groq

# Set the key for whichever provider you selected above.
GROQ_API_KEY=
NVIDIA_API_KEY=
# Optional: override the NVIDIA NIM model (defaults to meta/llama-3.3-70b-instruct).
# Other options: meta/llama-3.1-8b-instruct, nvidia/llama-3.1-nemotron-70b-instruct
NVIDIA_MODEL=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
HF_TOKEN=
