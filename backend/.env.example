# Local RAG backend environment. Copy to `.env` and fill in as needed.
# Retrieval + embeddings always run locally. Answer generation uses the provider
# selected below; only that provider's API key is required.

# --- Provider selection: groq | nvidia | gemini | openrouter | hf | local ---
LLM_PROVIDER=groq

# --- Provider API keys (set the one matching LLM_PROVIDER) ---
# Groq (free, fast): https://console.groq.com/keys
GROQ_API_KEY=
# NVIDIA NIM (free credits): https://build.nvidia.com  (key starts with nvapi-)
NVIDIA_API_KEY=
# Google Gemini (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# OpenRouter (has :free models): https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Hugging Face Inference: https://huggingface.co/settings/tokens
HF_TOKEN=

# --- Optional per-provider model overrides (blank = provider default) ---
# GROQ_MODEL=llama-3.3-70b-versatile
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# GEMINI_MODEL=gemini-2.0-flash
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# --- Local HF LLM (only used when LLM_PROVIDER=local) ---
# LLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# --- Generation knobs (shared across providers) ---
# LLM_MAX_NEW_TOKENS=512
# LLM_TEMPERATURE=0.3
# LLM_CONTEXT_CHAR_BUDGET=6000

# --- Retrieval ---
# TOP_K=4

# --- Storage (point at a persistent volume in the cloud, e.g. /data on Fly.io) ---
# DATA_DIR=/data

# --- CORS: comma-separated frontend origins, or * for any ---
CORS_ORIGINS=*

# --- Logging: DEBUG | INFO | WARNING | ERROR ---
LOG_LEVEL=INFO
